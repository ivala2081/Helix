# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhb...
SUPABASE_SERVICE_ROLE_KEY=eyJhb...

# ── Cron authentication ──
CRON_SECRET=random-hex-string

# ── Telegram alerts (optional) ──
# Create a bot via @BotFather, get chat ID via @userinfobot
# If not set, notifications are silently disabled.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=-1001234567890

# ── GitHub Actions secrets (for cron workflow) ──
# VERCEL_URL=https://helix-coral-six.vercel.app
# CRON_SECRET=must match server-side value
